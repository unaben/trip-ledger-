# Copy this file to .env and fill in your real Hostinger values.
# .env is already git-ignored via .env* in .gitignore - never commit real credentials.
#
# Prisma 7 needs BOTH of these:
#   - DATABASE_URL is read by prisma.config.ts, used only by the Prisma CLI
#     (`prisma generate`, `prisma db pull`, `prisma studio`)
#   - DATABASE_HOST/PORT/USER/PASSWORD/NAME are read by lib/prisma.ts at
#     runtime, used by the actual running app via the driver adapter
#
# hPanel -> Databases -> Remote MySQL -> "remote MySQL hostname"
# e.g. srv1593.hstgr.io (prefer the hostname over the raw IP - it survives
# Hostinger migrating your DB to a different server)

DATABASE_URL="mysql://u342744702_admin:YOUR_PASSWORD@srv1593.hstgr.io:3306/u342744702_trips"

DATABASE_HOST=srv1593.hstgr.io
DATABASE_PORT=3306
DATABASE_USER=u342744702_admin
DATABASE_PASSWORD=YOUR_PASSWORD
DATABASE_NAME=u342744702_trips

# Used to sign/verify session cookies (lib/auth/session.ts). Must be a long,
# random, secret string - generate one with:
#   openssl rand -base64 48
# Rotating this instantly invalidates every existing session (forces
# everyone to log in again), so treat it like a password, not a config
# toggle.
SESSION_SECRET=